{
  "name": "rybitten",
  "version": "0.31.0",
  "keywords": [
    "color",
    "ryb",
    "colour",
    "palettes",
    "palette",
    "color-manipulation",
    "data visualization",
    "color theory",
    "color manipulation",
    "color palettes"
  ],
  "description": "A color space conversion library for transforming between RGB and RYB colors.",
  "author": "meodai",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src/cubes.ts",
    "src/main.ts",
    "src/p5-extension.ts",
    "src/vite-env.d.ts",
    "CHANGELOG.md",
    "STABILITY.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/rybitten.mjs",
      "require": "./dist/rybitten.cjs",
      "types": "./dist/main.d.ts"
    },
    "./cubes": {
      "import": "./dist/cubes.mjs",
      "require": "./dist/cubes.cjs",
      "types": "./dist/cubes.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "cubes": [
        "./dist/cubes.d.ts"
      ],
      "*": [
        "./dist/main.d.ts"
      ]
    }
  },
  "main": "./dist/rybitten.cjs",
  "module": "./dist/rybitten.mjs",
  "unpkg": "./dist/rybitten.umd.js",
  "types": "./dist/main.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meodai/RYBitten.git"
  },
  "bugs": {
    "url": "https://github.com/meodai/RYBitten/issues"
  },
  "homepage": "https://meodai.github.io/RYBitten/",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --open src/index.html",
    "dev:p5": "vite --open src/p5.html",
    "build": "npm run build:lib && npm run build:html",
    "build:html": "vite build --config vite.configdemo.js",
    "build:umd": "vite build --config vite.config.umd.js --outDir dist",
    "build:p5": "vite build --config vite.config.p5.js --outDir dist",
    "build:lib": "npm run lint && tsc && vite build --outDir dist && npm run build:umd && npm run build:p5",
    "lint": "eslint && npx prettier --check ./src/",
    "prettier": "npx prettier --write ./src/",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "smoke:pack": "node scripts/smoke-pack.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/p5": "^1.7.7",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-singlefile": "^2.0.1",
    "vitest": "^3.2.4"
  }
}
